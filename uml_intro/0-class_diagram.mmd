classDiagram
    class Library {
        +add_book()
        +register_user()
        +create_loan()
    }

    class Book {
        +title: str
        +author: str
        +available: bool
        +mark_as_unavailable()
        +mark_as_available()
    }

    class User {
        +name: str
        +email: str
    }

    class Loan {
        +start_date: str
        +end_date: str
        +close_loan()
    }

    Library "1" --> "0..*" Book : manages
    Library "1" --> "0..*" User : manages
    Library "1" --> "0..*" Loan : manages
    Loan "0..*" --> "1" Book : references
    Loan "0..*" --> "1" User : references
